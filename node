cleanData.forEach((raw) => {
  const row = normalizeRow(raw);

  if (!row.Domain && !row.System_Name) return;

  const domainId = addNode(row.Domain, 0);

  const geoId = addNode(
    `${row.Domain}|${row.Geography}`,
    1,
    row.Geography
  );

  const dpDispId = addNode(
    `${row.Domain}|${row.Geography}|${row.DP_Disposition}`,
    2,
    row.DP_Disposition
  );

  const platformId = addNode(
    `${row.Domain}|${row.Geography}|${row.DP_Disposition}|${row.Data_Platform}`,
    3,
    row.Data_Platform
  );

  const techId = addNode(
    `${row.Domain}|${row.Geography}|${row.DP_Disposition}|${row.Data_Platform}|${row.DP_Technology}`,
    4,
    row.DP_Technology
  );

  const sysDispId = addNode(
    `${row.Domain}|${row.Geography}|${row.DP_Disposition}|${row.Data_Platform}|${row.DP_Technology}|${row.System_Disposition}`,
    5,
    row.System_Disposition
  );

  const roleLabel = row.Source ? "Source" : row.Consuming ? "Consuming" : "Unknown";

  const roleId = addNode(
    `${row.Domain}|${row.Geography}|${row.DP_Disposition}|${row.Data_Platform}|${row.DP_Technology}|${row.System_Disposition}|${roleLabel}`,
    6,
    roleLabel
  );

  const systemName = row.System_Name || "Unknown";

  const systemId = addNode(
    `${row.Domain}|${row.Geography}|${row.DP_Disposition}|${row.Data_Platform}|${row.DP_Technology}|${row.System_Disposition}|${roleLabel}|${systemName}`,
    7,
    systemName
  );

  // edges (same chain)
  addEdge(domainId, geoId);
  addEdge(geoId, dpDispId);
  addEdge(dpDispId, platformId);
  addEdge(platformId, techId);
  addEdge(techId, sysDispId);
  addEdge(sysDispId, roleId);
  addEdge(roleId, systemId);
});
