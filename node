const [selectedPath, setSelectedPath] = useState([]);


const onNodeClick = useCallback(
  (_, node) => {
    if (isLeafNode(node.id)) return;

    // 🔥 build path properly
    let path = [node.id];
    let current = node.id;

    while (parentMap[current] && parentMap[current].length > 0) {
      const parent = parentMap[current][0]; // selected branch
      path.unshift(parent);
      current = parent;
    }

    setSelectedPath(path);

    const children = childrenMap[node.id] || [];

    // 🔥 FILTER CHILDREN BASED ON PATH
    const filteredChildren = children.filter((childId) => {
      return childId.startsWith(node.id); 
      // 🔥 works because deeper nodes use path-based IDs
    });

    const newVisible = new Set();

    // keep domain always visible
    nodesData.forEach((n) => {
      if (n.level === 0) newVisible.add(n.id);
    });

    path.forEach((p) => newVisible.add(p));
    filteredChildren.forEach((c) => newVisible.add(c));

    setVisibleNodeIds(newVisible);
    setActiveNode(node.id);
  },
  [childrenMap, parentMap, nodesData]
);





