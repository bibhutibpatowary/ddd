const [selectedDomain, setSelectedDomain] = useState(null);



const onNodeClick = useCallback(
  (_: any, node: any) => {
    if (isLeafNode(node.id)) return;

    const nodeData = nodeMap.get(node.id);

    let currentDomain = selectedDomain;

    // ✅ If clicked Domain → set it
    if (nodeData.level === 0) {
      currentDomain = nodeData.id;
      setSelectedDomain(currentDomain);
    }

    const ancestors = getAllAncestors(node.id);

    let children: any[] = [];

    // 🔥 KEY FIX: filter children ONLY for Geography level
    if (nodeData.level === 1 && currentDomain) {
      children = (childrenMap[node.id] || []).filter((childId) =>
        childId.startsWith(`${node.id}|`) &&
        edgesData.some(
          (e: any) =>
            e.source === currentDomain && e.target === node.id
        )
      );
    } else {
      children = childrenMap[node.id] || [];
    }

    const newVisible: any = new Set();

    // ✅ always keep Domains
    nodesData.forEach((n: any) => {
      if (n.level === 0) newVisible.add(n.id);
    });

    ancestors.forEach((a) => newVisible.add(a));
    newVisible.add(node.id);
    children.forEach((c: any) => newVisible.add(c));

    setVisibleNodeIds(newVisible);
    setActiveNode(node.id);
  },
  [childrenMap, nodeMap, nodesData, selectedDomain, edgesData]
);






