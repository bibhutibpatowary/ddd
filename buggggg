const getReachableNodes = (visibleRoots: any, childrenMap: any) => {
  const visited = new Set();

  const dfs = (nodeId: any) => {
    if (visited.has(nodeId)) return;
    visited.add(nodeId);

    (childrenMap[nodeId] || []).forEach(dfs);
  };

  visibleRoots.forEach((root: any) => dfs(root));

  return visited;
};



