setVisibleNodeIds((prev: any) => {
  const updated = new Set(prev);

  const areChildrenVisible = children.some((c: any) =>
    updated.has(c)
  );

  if (areChildrenVisible) {
    // 🔥 collapse entire branch from clicked node
    const descendants = getAllDescendants(node.id, childrenMap);

    descendants.forEach((d: any) => {
      updated.delete(d);
    });

    // remove path beyond clicked node
    setSelectedPath((prevPath: any) => {
      const index = prevPath.indexOf(node.id);
      return index !== -1
        ? prevPath.slice(0, index + 1)
        : prevPath;
    });

  } else {
    // expand
    children.forEach((c: any) => updated.add(c));
  }

  // always keep level 0 visible
  nodesData.forEach((n: any) => {
    if (n.level === 0) updated.add(n.id);
  });

  return updated;
});
