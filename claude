const buildReverseEdges = (
  startNodeId: string,
  allowedNodes: Set<string>,
  branchPath: string[] // ✅ Add branch context
) => {
  const visitedNodes = new Set<string>();
  const visitedEdges = new Set<string>();
  const edges: { source: string; target: string }[] = [];

  // ✅ Convert branch path to Set for O(1) lookup
  const branchNodeSet = new Set(branchPath);

  const dfs = (nodeId: string) => {
    visitedNodes.add(nodeId);

    const parents = parentMap[nodeId] || [];

    parents.forEach((parentId: string) => {
      // ✅ Must be visible AND in the same branch path
      if (!allowedNodes.has(parentId)) return;
      if (!branchNodeSet.has(parentId)) return;

      const edgeKey = `${nodeId}->${parentId}`;

      if (visitedEdges.has(edgeKey)) return;

      visitedEdges.add(edgeKey);

      edges.push({
        source: nodeId,
        target: parentId
      });

      if (!visitedNodes.has(parentId)) {
        dfs(parentId);
      }
    });
  };

  dfs(startNodeId);

  return edges;
};


