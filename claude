const onNodeClick = useCallback(
  (_: any, node: any) => {
    if (isLeafNode(node.id)) {
      setActiveReverseLeaf((prev) => {
        const isSame = prev === node.id;

        if (isSame) {
          return null;
        }

        const reverseEdges = buildReverseEdges(node.id, visibleNodeIds);

        setVisibleNodeIds((prevVisible: any) => {
          const updated = new Set(prevVisible);

          reverseEdges.forEach((e: any) => {
            updated.add(e.source);
            updated.add(e.target);
          });

          const visitedParents = new Set<string>();

          const openParentsRecursively = (currentId: string) => {
            if (visitedParents.has(currentId)) return;

            visitedParents.add(currentId);

            const parents = parentMap[currentId] || [];

            parents.forEach((p: string) => {
              updated.add(p);

              const grandparents = parentMap[p] || [];

              grandparents.forEach((gp: string) => {
                updated.add(gp);
              });

              openParentsRecursively(p);
            });
          };

          openParentsRecursively(node.id);

          return updated;
        });

        return node.id;
      });

      return;
    }

    setActiveReverseLeaf(null);

    const nodeData = nodeMap.get(node.id);

    let currentDomain = selectedDomain;

    const activePath = nodePaths[node.id] || [node.id];

    if (nodeData.level === 0) {
      currentDomain = nodeData.label;
      setSelectedDomain(currentDomain);
      setSelectedPath([node.id]);
    } else {
      setSelectedPath(activePath);
    }

    // ✅ FIX: Exact branch matching for shared nodes
    let children = edgesData
      .filter((e: any) => {
        if (e.source !== node.id) return false;

        // Exact length + content match
        // activePath includes the clicked node
        // e.fullPath stores path UP TO (excluding) target
        // So for this edge, e.fullPath should exactly equal activePath
        if (e.fullPath.length !== activePath.length) return false;

        return e.fullPath.every(
          (pathNode: string, idx: number) =>
            activePath[idx] === pathNode
        );
      })
      .map((e: any) => e.target);

    // Level 1 domain filtering
    if (nodeData.level === 1 && currentDomain) {
      const filteredRows = rows.filter(
        (r: any) =>
          r.Domain === currentDomain &&
          r.Geography === nodeData.label
      );

      const validDPs = new Set(
        filteredRows.map((r: any) => r.DP_Disposition)
      );

      children = children.filter((childId: any) => {
        const label = nodeMap.get(childId)?.label;
        return validDPs.has(label);
      });
    }

    setVisibleNodeIds((prev: any) => {
      const updated = new Set(prev);

      const areChildrenVisible = children.every((c: any) =>
        updated.has(c)
      );

      if (areChildrenVisible) {
        const descendants = getAllDescendants(node.id, childrenMap);

        descendants.forEach((d: any) => updated.delete(d));

        setSelectedPath((prev: any) => {
          const index = prev.indexOf(node.id);
          if (index === -1) return prev;
          return prev.slice(0, index + 1);
        });

        descendants.forEach((d: any) => {
          if (updated.has(d)) {
            updated.delete(d);
          }
        });

        return updated;
      } else {
        // Remove descendants of sibling branches first
        const parentPath = activePath.slice(0, -1);

        const siblingNodes = Array.from(updated).filter((visibleId: any) => {
          const visiblePath = nodePaths[visibleId];

          if (!visiblePath) return false;

          const sameParent = parentPath.every(
            (p: string, idx: number) => visiblePath[idx] === p
          );

          const sameLevel =
            nodeMap.get(visibleId)?.level === nodeMap.get(node.id)?.level;

          const notCurrent = visibleId !== node.id;

          return sameParent && sameLevel && notCurrent;
        });

        // Remove sibling descendants
        siblingNodes.forEach((siblingId: any) => {
          const descendants = getAllDescendants(siblingId, childrenMap);

          descendants.forEach((d: any) => {
            updated.delete(d);
          });
        });

        // Cleanup shared-node descendants from other branches
        const currentNodePath = nodePaths[node.id] || [];

        Array.from(updated).forEach((visibleId: any) => {
          if (visibleId === node.id) return;

          const visibleNode = nodeMap.get(visibleId);
          const currentNode = nodeMap.get(node.id);

          if (
            visibleNode?.label === currentNode?.label &&
            visibleNode?.level === currentNode?.level
          ) {
            const visiblePath = nodePaths[visibleId] || [];

            const isDifferentBranch =
              JSON.stringify(visiblePath.slice(0, -1)) !==
              JSON.stringify(currentNodePath.slice(0, -1));

            if (isDifferentBranch) {
              const descendants = getAllDescendants(visibleId, childrenMap);

              descendants.forEach((d: any) => {
                updated.delete(d);
              });
            }
          }
        });

        // Add current children
        children.forEach((c: any) => updated.add(c));

        setNodePaths((prev: any) => {
          const updatedPaths = { ...prev };

          children.forEach((childId: string) => {
            updatedPaths[childId] = [...activePath, childId];
          });

          return updatedPaths;
        });

        // Keep root nodes visible
        nodesData.forEach((n: any) => {
          if (n.level === 0) updated.add(n.id);
        });

        return updated;
      }
    });

    setActiveNode(node.id);
  },
  [
    childrenMap,
    nodeMap,
    nodesData,
    selectedDomain,
    rows,
    edgesData,
    nodePaths,
    parentMap,
    visibleNodeIds
  ]
);
