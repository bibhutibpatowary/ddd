const edges = useMemo(() => {
  let finalEdges: any[] = [...edgesData];

  // Add reverse edges if leaf selected
  if (activeReverseLeaf) {
    // ✅ Get branch path for the active reverse leaf
    const leafBranchPath = nodePaths[activeReverseLeaf] || [activeReverseLeaf];

    const reverseEdges = buildReverseEdges(
      activeReverseLeaf,
      visibleNodeIds,
      leafBranchPath
    ).map((e, i) => ({
      id: `rev-${activeReverseLeaf}-${i}`,
      source: e.target,
      target: e.source,
      isReverse: true
    }));

    finalEdges = [...finalEdges, ...reverseEdges];
  }

  return finalEdges
    .filter(
      (e: any) =>
        visibleNodeIds.has(e.source) &&
        visibleNodeIds.has(e.target)
    )
    .map((e: any) => {
      const isPathEdge = selectedPath.some(
        (nodeId: any, index: number) =>
          selectedPath[index + 1] === e.target &&
          nodeId === e.source
      );

      return {
        ...e,
        type: "smoothstep",
        animated: isPathEdge || e.isReverse,

        ...(e.isReverse && {
          markerStart: {
            type: MarkerType.ArrowClosed,
            color: "#007bff",
            width: 20,
            height: 20
          }
        }),

        style: {
          stroke: e.isReverse
            ? "#007bff"
            : isPathEdge
              ? "red"
              : "#bbb",

          strokeWidth: e.isReverse ? 2 : isPathEdge ? 2.5 : 1,
          strokeDasharray: e.isReverse ? "5 5" : "0"
        }
      };
    });
}, [edgesData, visibleNodeIds, selectedPath, activeReverseLeaf, nodePaths]);
