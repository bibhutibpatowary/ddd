const getAllDescendants = (nodeId: any, childrenMap: any, visited = new Set()) => {
  if (visited.has(nodeId)) return visited;

  const children = childrenMap[nodeId] || [];

  children.forEach((child: any) => {
    visited.add(child);
    getAllDescendants(child, childrenMap, visited);
  });

  return visited;
};


