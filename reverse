setNodePaths((prev: any) => {
  const updatedPaths = { ...prev };

  children.forEach((childId: string) => {
    const newPath = [
      ...activePath,
      childId
    ];

    const existing =
      updatedPaths[childId] || [];

    // avoid duplicate path insertion
    const alreadyExists =
      existing.some(
        (p: string[]) =>
          JSON.stringify(p) ===
          JSON.stringify(newPath)
      );

    if (!alreadyExists) {
      updatedPaths[childId] = [
        ...existing,
        newPath
      ];
    }
  });

  return updatedPaths;
});

