let children =
  edgesData
    .filter((e: any) => {
      if (e.source !== node.id) return false;

      // 🔥 compare ONLY till current node level
      const edgePathTillCurrentNode =
        e.fullPath.slice(0, activePath.length);

      return edgePathTillCurrentNode.every(
        (pathNode: string, idx: number) =>
          activePath[idx] === pathNode
      );
    })
    .map((e: any) => e.target);
