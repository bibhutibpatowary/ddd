const isNodeUsedElsewhere = (
  nodeId: string,
  collapsingPath: string[],
  visibleNodeIds: Set<string>,
  nodePaths: Record<string, string[][]>
) => {

  const paths =
    nodePaths[nodeId] || [];

  return paths.some((path) => {

    // ignore collapsing branch
    const sameBranch =
      collapsingPath.every(
        (p, idx) => path[idx] === p
      );

    if (sameBranch) {
      return false;
    }

    // node still visible via another branch
    return path.every((p) =>
      visibleNodeIds.has(p)
    );
  });
};


