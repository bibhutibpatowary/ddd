let activePath: string[] = [];

// 🔥 root node
if (nodeData.level === 0) {
  activePath = [node.id];
} else {
  // 🔥 exact parent based on hierarchy level
  const parentNodeId =
    selectedPath[nodeData.level - 1];

  const matchedEdge = edgesData.find((e: any) => {
    return (
      e.source === parentNodeId &&
      e.target === node.id
    );
  });

  activePath = matchedEdge
    ? [...matchedEdge.fullPath, node.id]
    : [node.id];
}
