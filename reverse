let prevNodeId: string | null = null;

const currentPath: string[] = [];

columns.forEach((col: string, level: number) => {
  const value = String(row[col] || "").trim();

  if (!value) return;

  const nodeId = `${level}::${value}`;

  addNode(nodeId, level);

  const rootDomain = row[columns[0]];

  // 🔥 add current node into active hierarchy
  currentPath.push(nodeId);

  if (prevNodeId) {
    addEdge(
      prevNodeId,
      nodeId,
      rootDomain,

      // 🔥 store ONLY path up to SOURCE
      [...currentPath.slice(0, -1)]
    );
  }

  prevNodeId = nodeId;
});
