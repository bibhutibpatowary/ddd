let activePath: string[] = [];

// 🔥 root node
if (nodeData.level === 0) {
  activePath = [node.id];
} else {
  // 🔥 find exact clicked branch
  const matchedEdge: any = edgesData.find((e: any) => {
    return (
      e.target === node.id &&
      visibleNodeIds.has(e.source)
    );
  });

  activePath = matchedEdge
    ? [...matchedEdge.fullPath, node.id]
    : [node.id];
}
