// 🔥 get dynamic columns
const columns = Object.keys(cleanData[0] || {});

// 🔥 merge Source + Consuming into single logical column
const processedColumns = columns.map((col) =>
  col === "Source" || col === "Consuming" ? "Role" : col
);

// remove duplicates (because Source & Consuming both become Role)
const uniqueColumns = [...new Set(processedColumns)];

cleanData.forEach((raw: any) => {
  const row = normalizeRow(raw);

  let prevNodeId: string | null = null;

  uniqueColumns.forEach((col, level) => {
    let value = "";

    if (col === "Role") {
      value = row.Source ? "Source" : row.Consuming ? "Consuming" : "";
    } else {
      value = row[col];
    }

    if (!value) return;

    // 🔥 build unique hierarchical id
    const nodeId = prevNodeId
      ? `${prevNodeId}|${value}`
      : value;

    addNode(nodeId, level, value);

    if (prevNodeId) {
      addEdge(prevNodeId, nodeId);
    }

    prevNodeId = nodeId;
  });
});
