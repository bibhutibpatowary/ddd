setNodePaths((prev: any) => {
  const updatedPaths = { ...prev };

  children.forEach((childId: string) => {
    const newPath = [
      ...activePath,
      childId
    ];

    if (!updatedPaths[childId]) {
      updatedPaths[childId] = [];
    }

    // 🔥 avoid duplicate path insertions
    const alreadyExists =
      updatedPaths[childId].some(
        (p: string[]) =>
          JSON.stringify(p) === JSON.stringify(newPath)
      );

    if (!alreadyExists) {
      updatedPaths[childId].push(newPath);
    }
  });

  return updatedPaths;
});



