const getBranchDescendants = (
  startNodeId: string,
  activePath: string[],
  edgesData: any[],
  visited = new Set<string>()
) => {
  const children = edgesData
    .filter((e) => {
      if (e.source !== startNodeId) return false;

      // strict branch match
      if (
        e.fullPath.length !== activePath.length
      ) {
        return false;
      }

      return e.fullPath.every(
        (p: string, idx: number) =>
          activePath[idx] === p
      );
    })
    .map((e) => e.target);

  children.forEach((childId) => {
    if (!visited.has(childId)) {
      visited.add(childId);

      getBranchDescendants(
        childId,
        [...activePath, childId],
        edgesData,
        visited
      );
    }
  });

  return visited;
};


