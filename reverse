const incomingEdge = edgesData.find(
  (e: any) =>
    e.target === node.id &&
    visibleNodeIds.has(e.source)
);

// 🔥 reconstruct REAL active hierarchy
const activePath = incomingEdge
  ? [...incomingEdge.fullPath, node.id]
  : [node.id];

let children =
  edgesData
    .filter((e: any) => {
      if (e.source !== node.id) return false;

      // 🔥 exact branch matching
      return activePath.every(
        (pathNode, idx) =>
          e.fullPath[idx] === pathNode
      );
    })
    .map((e: any) => e.target);
