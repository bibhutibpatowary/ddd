const buildFullReverseAppend = (startId, startLevel) => {
  const newNodesMap = new Map();
  const newEdges = [];

  const visited = new Set();
  const queue = [{ id: startId, level: startLevel }];

  while (queue.length) {
    const { id, level } = queue.shift();

    if (visited.has(id)) continue;
    visited.add(id);

    const parents = parentMap[id] || [];

    parents.forEach((parentId) => {
      const originalParent = nodeMap.get(parentId);

      // 🔥 unique id to avoid collision
      const newId = `${startId}__rev__${parentId}`;

      if (!newNodesMap.has(newId)) {
        newNodesMap.set(newId, {
          id: newId,
          label: originalParent?.label,
          level: level + 1
        });
      }

      // edge from child → parent (reverse direction)
      newEdges.push({
        source: id,
        target: newId
      });

      queue.push({
        id: parentId,
        level: level + 1
      });
    });
  }

  return {
    newNodes: Array.from(newNodesMap.values()),
    newEdges
  };
};


