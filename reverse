if (isLeafNode(node.id)) {
  const reverseGraph = buildReverseGraph(node.id);

  setNodesData(reverseGraph.nodes);
  setEdgesData(
    reverseGraph.edges.map((e, i) => ({
      id: `rev-${i}`,
      ...e
    }))
  );

  setVisibleNodeIds(
    new Set(reverseGraph.nodes.map((n) => n.id))
  );

  setViewMode("reverse");
  setActiveNode(node.id);
  setSelectedPath([node.id]);

  return;
}
