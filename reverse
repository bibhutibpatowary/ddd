const existingPaths =
  allNodePaths[nodeId] || [];

const newPath = [...currentPath];

const alreadyExists =
  existingPaths.some(
    (p) =>
      JSON.stringify(p) ===
      JSON.stringify(newPath)
  );

if (!alreadyExists) {
  allNodePaths[nodeId] = [
    ...existingPaths,
    newPath
  ];
