const pathsEqual = (a: string[] = [], b: string[] = []) => {
  if (a.length !== b.length) return false;

  return a.every((nodeId, index) => nodeId === b[index]);
};

const isPrefixPath = (prefix: string[] = [], full: string[] = []) => {
  if (prefix.length > full.length) return false;

  return prefix.every((nodeId, index) => nodeId === full[index]);
};

const getBestPathForClickedNode = (
  nodeId: string,
  selectedPath: string[],
  activeNodePath: string[],
  nodePaths: Record<string, string[][]>
) => {
  const possiblePaths = nodePaths[nodeId] || [];

  if (possiblePaths.length === 0) {
    return [nodeId];
  }

  // 1. If currently selected path ends at this node, reuse it.
  // This is important when clicking a shared node again to collapse/expand.
  const selectedMatch = possiblePaths.find((path) =>
    pathsEqual(path, selectedPath)
  );

  if (selectedMatch) {
    return selectedMatch;
  }

  // 2. If previous active node path is parent of this clicked node,
  // use the child path under that active branch.
  const fromActiveParent = possiblePaths.find((path) => {
    const parentPath = path.slice(0, -1);
    return pathsEqual(parentPath, activeNodePath);
  });

  if (fromActiveParent) {
    return fromActiveParent;
  }

  // 3. If selected path is parent of this clicked node, use that branch.
  const fromSelectedParent = possiblePaths.find((path) => {
    const parentPath = path.slice(0, -1);
    return pathsEqual(parentPath, selectedPath);
  });

  if (fromSelectedParent) {
    return fromSelectedParent;
  }

  // 4. If clicked node is inside the selected path, use that prefix.
  const selectedPrefix = possiblePaths.find((path) =>
    isPrefixPath(path, selectedPath)
  );

  if (selectedPrefix) {
    return selectedPrefix;
  }

  // 5. Prefer a path whose parent is visible, but only as fallback.
  const visibleParentMatch = possiblePaths.find((path) => {
    if (path.length === 1) return true;

    const parentId = path[path.length - 2];
    return visibleNodeIds.has(parentId);
  });

  return visibleParentMatch || possiblePaths[0] || [nodeId];
};


