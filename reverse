const buildReverseAppend = (startId, startLevel) => {
  const newNodes = [];
  const newEdges = [];

  const visited = new Set();
  const queue = [{ id: startId, level: startLevel }];

  while (queue.length) {
    const { id, level } = queue.shift();

    if (visited.has(id)) continue;
    visited.add(id);

    const parents = parentMap[id] || [];

    parents.forEach((p) => {
      // 🔥 create unique id (to avoid clash)
      const newId = `${id}__parent__${p}`;

      newNodes.push({
        id: newId,
        label: nodeMap.get(p)?.label,
        level: level + 1
      });

      newEdges.push({
        source: id,
        target: newId
      });

      queue.push({ id: p, level: level + 1 });
    });
  }

  return { newNodes, newEdges };
};


