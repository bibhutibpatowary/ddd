const [activeReverseNodes, setActiveReverseNodes] = useState(new Set());


if (isLeafNode(node.id)) {

  setActiveReverseNodes((prev) => {
    const updated = new Set(prev);

    if (updated.has(node.id)) {
      // 🔴 toggle OFF → remove highlight only
      updated.delete(node.id);
    } else {
      // 🟢 toggle ON → ensure reverse edges exist
      const reverseGraph = buildReverseGraph(node.id);

      const newEdges = reverseGraph.edges.map((e, i) => ({
        id: `rev-${node.id}-${i}`,
        ...e,
        isReverse: true,
        parentLeaf: node.id // 🔥 important
      }));

      setEdgesData((prevEdges) => {
        const existing = new Set(prevEdges.map(e => e.id));
        const filtered = newEdges.filter(e => !existing.has(e.id));
        return [...prevEdges, ...filtered];
      });

      // ❗ DO NOT touch nodesData or visibleNodeIds
      updated.add(node.id);
    }

    return updated;
  });

  setActiveNode(node.id);
  return;
}



const edges = useMemo(() => {
  return edgesData
    .filter((e) => {
      // 🔥 hide reverse edges if not active
      if (e.isReverse && !activeReverseNodes.has(e.parentLeaf)) {
        return false;
      }

      return (
        visibleNodeIds.has(e.source) &&
        visibleNodeIds.has(e.target)
      );
    })
    .map((e) => {
      const isPathEdge =
        selectedPath.includes(e.source) &&
        selectedPath.includes(e.target);

      return {
        ...e,
        type: "smoothstep",
        animated:
          activeNode &&
          (e.source === activeNode || e.target === activeNode),

        style: {
          stroke: e.isReverse
            ? "#007bff"   // 🔵 reverse
            : isPathEdge
            ? "red"
            : "#999",

          strokeWidth: e.isReverse ? 2 : 1.5,
          strokeDasharray: e.isReverse ? "5 5" : "0"
        }
      };
    });
}, [edgesData, visibleNodeIds, activeNode, selectedPath, activeReverseNodes]);
