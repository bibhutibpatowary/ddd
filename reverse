const columns: string[] = Object.keys(cleanData[0] || {});

cleanData.forEach((raw: any) => {
  const row = normalizeRow(raw);

  let prevNodeId: string | null = null;

  columns.forEach((col: string, level: number) => {
    const value = row[col];
    if (!value) return;

    const nodeId = prevNodeId
      ? `${prevNodeId}|${value}`
      : value;

    addNode(nodeId, level, value);

    if (prevNodeId) {
      addEdge(prevNodeId, nodeId);
    }

    prevNodeId = nodeId;
  });
});
