} else {

  // 🔥 ONLY valid children for selected branch
  const validChildren = edgesData
    .filter((e: any) => {
      if (e.source !== node.id) return false;

      return (
        JSON.stringify(e.fullPath) ===
        JSON.stringify(activePath)
      );
    })
    .map((e: any) => e.target);

  validChildren.forEach((c: any) => updated.add(c));

  // 🔥 preserve exact hierarchy path
  setNodePaths((prev: any) => {
    const updatedPaths = { ...prev };

    validChildren.forEach((childId: string) => {
      updatedPaths[childId] = [
        ...activePath,
        childId
      ];
    });

    return updatedPaths;
  });

  nodesData.forEach((n: any) => {
    if (n.level === 0) updated.add(n.id);
  });

  return updated;
}
