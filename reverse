if (isLeafNode(node.id)) {

  const currentNode = nodeMap.get(node.id);
  const startLevel = currentNode?.level || 0;

  const { newNodes, newEdges } = buildReverseAppend(
    node.id,
    startLevel
  );

  // ✅ Append (not replace)
  setNodesData((prev) => [...prev, ...newNodes]);

  setEdgesData((prev) => [
    ...prev,
    ...newEdges.map((e, i) => ({
      id: `rev-${Date.now()}-${i}`,
      ...e
    }))
  ]);

  setVisibleNodeIds((prev) => {
    const updated = new Set(prev);

    newNodes.forEach((n) => updated.add(n.id));

    return updated;
  });

  setActiveNode(node.id);

  return;
}
