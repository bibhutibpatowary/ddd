const nodeId = value.trim();




const nodesMap = new Map();
const edgesSet = new Set();

const columns: string[] = Object.keys(cleanData[0] || {});

const addNode = (id: string, level: number) => {
  if (!nodesMap.has(id)) {
    nodesMap.set(id, {
      id,
      label: id,
      level
    });
  }
};

const addEdge = (source: string, target: string) => {
  edgesSet.add(`${source}->${target}`);
};

cleanData.forEach((raw: any) => {
  const row = normalizeRow(raw);

  let prevNodeId: string | null = null;

  columns.forEach((col: string, level: number) => {
    const value = String(row[col] || "").trim();

    if (!value) return;

    // 🔥 SAME NODE SHARED GLOBALLY
    const nodeId = value;

    addNode(nodeId, level);

    if (prevNodeId) {
      addEdge(prevNodeId, nodeId);
    }

    prevNodeId = nodeId;
  });
});
