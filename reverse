const [backtrackEdges, setBacktrackEdges] = useState<any[]>([]);


const getBacktrackEdges = (nodeId: any, parentMap: any) => {
  const edges: any[] = [];
  const visited = new Set();

  const dfs = (child: any) => {
    const parents = parentMap[child] || [];

    parents.forEach((parent: any) => {
      const key = `${child}->${parent}`;
      if (!visited.has(key)) {
        visited.add(key);

        edges.push({
          source: child,
          target: parent
        });

        dfs(parent);
      }
    });
  };

  dfs(nodeId);
  return edges;
};




