if (isLeafNode(node.id)) {

  const startLevel = nodeMap.get(node.id)?.level || 0;

  const { newNodes, newEdges } = buildFullReverseAppend(
    node.id,
    startLevel
  );

  // ✅ append nodes
  setNodesData((prev) => {
    const existingIds = new Set(prev.map((n) => n.id));
    const filtered = newNodes.filter((n) => !existingIds.has(n.id));
    return [...prev, ...filtered];
  });

  // ✅ append edges
  setEdgesData((prev) => [
    ...prev,
    ...newEdges.map((e, i) => ({
      id: `rev-${Date.now()}-${i}`,
      ...e
    }))
  ]);

  // ✅ show them
  setVisibleNodeIds((prev) => {
    const updated = new Set(prev);
    newNodes.forEach((n) => updated.add(n.id));
    return updated;
  });

  setActiveNode(node.id);

  return;
}
