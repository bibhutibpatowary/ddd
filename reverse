const systemParentMap: any = {};

cleanData.forEach((row: any) => {
  const firstParent = Object.values(row)[0]; // first column
  const systemName = row.System_Name;

  if (!systemParentMap[systemName]) {
    systemParentMap[systemName] = new Set();
  }

  systemParentMap[systemName].add(firstParent);
});

Object.entries(systemParentMap).forEach(([system, parents]: any) => {
  if (parents.size > 1) {
    console.log(system, [...parents]);
  }
});
