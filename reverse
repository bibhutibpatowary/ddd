const edges = useMemo(() => {
  const normalEdges = edgesData
    .filter(
      (e: any) =>
        visibleNodeIds.has(e.source) &&
        visibleNodeIds.has(e.target)
    )
    .map((e: any) => {
      const isPathEdge = selectedPath.some(
        (nodeId: any, index: number) =>
          selectedPath[index + 1] === e.target &&
          nodeId === e.source
      );

      return {
        ...e,
        type: "smoothstep",
        animated: isPathEdge,
        style: {
          stroke: isPathEdge ? "red" : "#bbb",
          strokeWidth: isPathEdge ? 2.5 : 1
        }
      };
    });

  // 🔥 BACKTRACK EDGES (reverse direction)
  const reverseEdges = backtrackEdges.map((e: any, i: number) => ({
    id: `back-${i}`,

    // 🔥 reverse direction visually
    source: e.target,
    target: e.source,

    type: "smoothstep",
    animated: true,
    style: {
      stroke: "#FF5733",
      strokeWidth: 3,
      strokeDasharray: "5,5"
    }
  }));

  return [...normalEdges, ...reverseEdges];
}, [edgesData, visibleNodeIds, selectedPath, backtrackEdges]);

