const matchingEdge = edgesData.find(
  (e: any) =>
    e.target === node.id &&
    visibleNodeIds.has(e.source)
);

// 🔥 actual hierarchy path till clicked node
const activePath = matchingEdge
  ? [...matchingEdge.fullPath, node.id]
  : [node.id];

children =
  edgesData
    .filter((e: any) => {
      if (e.source !== node.id) return false;

      // 🔥 strict hierarchy match
      return activePath.every(
        (pathNode, idx) =>
          e.fullPath[idx] === pathNode
      );
    })
    .map((e: any) => e.target);
