const getBestPathForClickedNode = (
  nodeId: string,
  selectedPath: string[],
  activeRootId: string | null,
  nodePaths: Record<string, string[][]>
) => {
  const possiblePaths = nodePaths[nodeId] || [];

  if (possiblePaths.length === 0) {
    return [nodeId];
  }

  // 1. EXACT MATCH
  const exactMatch = possiblePaths.find((path) =>
    pathsEqual(path, selectedPath)
  );

  if (exactMatch) {
    return exactMatch;
  }

  // 2. STRONGEST PREFIX MATCH
  // This is the REAL fix
  let bestMatch: string[] | null = null;
  let bestScore = -1;

  possiblePaths.forEach((path) => {
    let score = 0;

    for (
      let i = 0;
      i < Math.min(path.length, selectedPath.length);
      i++
    ) {
      if (path[i] === selectedPath[i]) {
        score++;
      } else {
        break;
      }
    }

    if (score > bestScore) {
      bestScore = score;
      bestMatch = path;
    }
  });

  if (bestMatch) {
    return bestMatch;
  }

  // 3. ROOT FALLBACK
  if (activeRootId) {
    const rootMatch = possiblePaths.find(
      (path) => path[0] === activeRootId
    );

    if (rootMatch) {
      return rootMatch;
    }
  }

  // 4. DEFAULT
  return possiblePaths[0];
};
